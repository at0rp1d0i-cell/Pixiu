# EvoQuant Sandbox for OpenCode Agent
# 基于 Python 3.12 (与宿主机一致) 构建安全的隔离计算环境
FROM python:3.12-slim

# 设置工作目录
WORKDIR /app

# 安装必要的系统库和 Node.js (OpenCode 依赖 Node 环境)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    build-essential \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 全局安装 Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# 安装 Qlib 和基础科学计算库 (与宿主机保持对齐)
# 绕过 PEP 668，因为我们在独立的 Docker 容器内
RUN pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple && \
    pip install --no-cache-dir --break-system-packages \
    numpy \
    pandas \
    scipy \
    scikit-learn \
    lightgbm \
    yfinance \
    tqdm \
    matplotlib \
    pyqlib

# /app/data        -> 宿主机的 qlib_bin 数据 (只读挂载)
# /app/workspace   -> 宿主机的策略代码目录 (读写挂载)
# /app/skills      -> 代理专属系统编程法则 (只读挂载)
VOLUME ["/app/data", "/app/workspace", "/app/skills"]

# 设置运行环境变量 (将在外部被 override)
ENV ANTHROPIC_API_KEY="placeholder"
ENV ANTHROPIC_BASE_URL="placeholder"

# 默认运行 bash，防止容器秒退
CMD ["/bin/bash"]
