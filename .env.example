# Pixiu runtime environment
# Copy to .env for local development.

# ── Research / LLM runtime ─────────────────────────────
# Runtime role->provider + model selection is configured in config/llm_runtime.json.
# Env stores provider endpoints/secrets for the current openai-compatible runtime.
DEEPSEEK_API_BASE=
DEEPSEEK_API_KEY=
OPENAI_API_BASE=
OPENAI_API_KEY=
# Optional quick global switch for default provider (does not override role-specific provider in settings).
PIXIU_LLM_DEFAULT_PROVIDER=

# Legacy compatibility fallback (used only when runtime settings are missing/invalid).
RESEARCHER_MODEL=deepseek-chat
RESEARCHER_BASE_URL=
RESEARCHER_API_KEY=
OPENAI_MODEL=

# Reserved for future/non-default providers. Current MVP runtime does not instantiate
# Anthropic/Gemini-specific SDK clients yet.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
CODER_MODEL=

# ── Orchestrator / Control Plane ───────────────────────
MAX_ROUNDS=20
ACTIVE_ISLANDS=momentum,northbound,valuation,volatility,volume,sentiment
REPORT_EVERY_N_ROUNDS=5
MAX_CONCURRENT_BACKTESTS=2
PIXIU_STATE_STORE_PATH=./data/control_plane_state.db

# ── Data / Feature Flags ───────────────────────────────
FUNDAMENTAL_FIELDS_ENABLED=false
TUSHARE_TOKEN=
TAVILY_API_KEY=

# Qlib data is currently discovered from the repo-local ./data/qlib_bin path.
# Keep this documented here for operators, even though the current runtime does not read this env var.
QLIB_DATA_DIR=./data/qlib_bin
